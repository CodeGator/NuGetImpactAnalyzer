<Window x:Class="NuGetImpactAnalyzer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:NuGetImpactAnalyzer.Views"
        xmlns:models="clr-namespace:NuGetImpactAnalyzer.Models"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="900" Width="1040"
        MinHeight="640" MinWidth="720"
        WindowStartupLocation="Manual"
        Background="#F4F4F6">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/ImpactPanelTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="#1D1D1F"/>
                <Setter Property="FontSize" Value="13"/>
            </Style>
            <Style TargetType="Button">
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Menu Grid.Row="0" Background="#F4F4F6" Padding="4,2,4,0">
            <MenuItem Header="_File" FontSize="13">
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Edit" FontSize="13">
                <MenuItem Header="Change master _password…" Command="{Binding ChangeMasterPasswordCommand}"/>
                <Separator/>
                <MenuItem Header="_Log out" Command="{Binding LogoutCommand}"/>
            </MenuItem>
            <MenuItem Header="_Help" FontSize="13">
                <MenuItem Header="_About…" Command="{Binding AboutCommand}"/>
            </MenuItem>
        </Menu>
        <TabControl Grid.Row="1" Margin="12,8,12,12" BorderThickness="0" Background="Transparent">
            <TabItem Header="Analyzer">
                <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" MinWidth="200"/>
            <ColumnDefinition Width="6"/>
            <ColumnDefinition Width="*" MinWidth="280"/>
        </Grid.ColumnDefinitions>

        <!-- Dependency graph -->
        <Border Grid.Column="0" Background="White" BorderBrush="#DCDCDE" BorderThickness="1" CornerRadius="6" Padding="12">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <TextBlock Text="Dependency graph" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Build Graph"
                                Command="{Binding Graph.BuildGraphCommand}"
                                HorizontalAlignment="Left"
                                ToolTip="Uses all repositories on the Settings tab. Per-repo analysis scope: Settings → Edit."/>
                        <ProgressBar Width="20" Height="20" IsIndeterminate="True" Margin="12,0,0,0"
                                     Visibility="{Binding Graph.IsBuildingGraph, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>
                <TabControl BorderThickness="0">
                    <TabItem Header="Text">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                            <TextBox Text="{Binding Graph.GraphText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     FontFamily="Cascadia Mono, Consolas, Courier New"
                                     FontSize="12"
                                     Foreground="#2D2D2D"
                                     Padding="4"/>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Graph">
                        <views:DependencyGraphDiagramView DataContext="{Binding Graph}"/>
                    </TabItem>
                </TabControl>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="6"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#D8D8DC"
                      Opacity="0.85"
                      Cursor="SizeWE"
                      ShowsPreview="False"/>

        <!-- Impact -->
        <Border Grid.Column="2" Background="White" BorderBrush="#DCDCDE" BorderThickness="1" CornerRadius="6" Padding="10"
                IsEnabled="{Binding Impact.IsGraphBuilt}">
            <DockPanel LastChildFill="True">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="0,4,0,0">
                            <TextBlock Text="Target Package" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ComboBox SelectedItem="{Binding Impact.TargetPackage, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding Impact.TargetPackageChoices}"
                                      IsEditable="False"
                                      IsTextSearchEnabled="True"
                                      Padding="6,4" Margin="0,0,0,8"
                                      ToolTip="Pick a repo/project from the list after Build Graph. Last target is saved in Data/userpreferences.json."/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Button Content="Analyze"
                                        Command="{Binding Impact.AnalyzeCommand}"
                                        IsEnabled="{Binding Impact.CanAnalyze}"
                                        Margin="0,0,8,0"/>
                                <StackPanel Orientation="Horizontal" Visibility="{Binding Impact.IsAnalyzingImpact, Converter={StaticResource BoolToVis}}">
                                    <ProgressBar Width="18" Height="18" IsIndeterminate="True" Margin="0,0,8,0"/>
                                    <TextBlock Text="Analyzing…" VerticalAlignment="Center" FontSize="11" Foreground="#666"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Text="{Binding Impact.ImpactHint}" TextWrapping="Wrap" FontSize="12" Foreground="#444" Margin="0,0,0,10"/>
                            <GroupBox Header="Impacted packages" BorderBrush="#E0E0E0" Padding="8" Margin="0,0,0,10">
                                <ItemsControl ItemsSource="{Binding Impact.ImpactedPackages}"
                                              FontSize="12"
                                              MaxHeight="200"
                                              ItemTemplate="{StaticResource ImpactedPackageResultRow}"/>
                            </GroupBox>
                            <TextBlock Text="{Binding Impact.BuildOrder.Hint}" TextWrapping="Wrap" FontSize="12" Foreground="#444" Margin="0,0,0,6"/>
                            <GroupBox Header="Build order" BorderBrush="#E0E0E0" Padding="8">
                                <ItemsControl ItemsSource="{Binding Impact.BuildOrder.Lines}"
                                              FontFamily="Cascadia Mono, Consolas, Courier New"
                                              FontSize="12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,4"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
            </DockPanel>
        </Border>
                </Grid>
            </TabItem>
            <TabItem Header="Repositories">
                <DockPanel LastChildFill="True" Margin="0" Background="#F4F4F6">
                    <Border DockPanel.Dock="Top" Background="White" BorderBrush="#DCDCDE" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <WrapPanel Orientation="Horizontal">
                                <Button Content="Add" Command="{Binding Workspace.AddRepositoryCommand}" Margin="0,0,8,6"/>
                                <Button Content="Sync repos" Command="{Binding Sync.SyncReposCommand}" Margin="0,0,8,6"/>
                                <Button Content="Clear clones" Command="{Binding Sync.ClearClonesCommand}" Margin="0,0,8,6"/>
                                <Button Content="Explore" Command="{Binding Sync.ExploreRepositoriesFolderCommand}" Margin="0,0,8,6"/>
                            </WrapPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding Sync.IsSyncingRepositories, Converter={StaticResource BoolToVis}}">
                                <ProgressBar Width="18" Height="18" IsIndeterminate="True" Margin="0,0,8,0"/>
                                <TextBlock Text="Syncing…" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" Visibility="{Binding Sync.IsClearingClones, Converter={StaticResource BoolToVis}}">
                                <ProgressBar Width="18" Height="18" IsIndeterminate="True" Margin="0,0,8,0"/>
                                <TextBlock Text="Clearing local clones…" VerticalAlignment="Center" FontSize="11" Foreground="#555"/>
                            </StackPanel>
                            <DockPanel Margin="0,12,0,0" LastChildFill="True">
                                <TextBlock DockPanel.Dock="Left" Text="Search" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#555"/>
                                <TextBox Text="{Binding Workspace.RepositorySearchText, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalContentAlignment="Center"
                                         Padding="8,6"
                                         BorderBrush="#C8C8CC"/>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#DCDCDE" BorderThickness="1" CornerRadius="6" Padding="0" ClipToBounds="True">
                        <DataGrid ItemsSource="{Binding Workspace.RepositoriesView}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserSortColumns="True"
                                  HeadersVisibility="Column"
                                  SelectionMode="Single"
                                  IsReadOnly="True"
                                  EnableRowVirtualization="False"
                                  SelectionChanged="SettingsRepositoriesGrid_SelectionChanged"
                                  GridLinesVisibility="Horizontal"
                                  BorderThickness="0"
                                  Margin="0"
                                  FontSize="13">
                            <!-- No selection chrome: row can still get a transient Selected state before code clears it. -->
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#FFFFFF"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#1D1D1F"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#FFFFFF"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="#1D1D1F"/>
                            </DataGrid.Resources>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="160">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1D1D1F"/>
                                            <Style.Triggers>
                                                <!-- Orange: private GitHub repo without PAT, or any repo with stored PAT. PAT trigger last so credentialed rows stay orange even when public. -->
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding GitHubIsPrivate}" Value="True"/>
                                                        <Condition Binding="{Binding HasStoredCredentials}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="#EA580C"/>
                                                </MultiDataTrigger>
                                                <DataTrigger Binding="{Binding HasStoredCredentials}" Value="True">
                                                    <Setter Property="Foreground" Value="#EA580C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTextColumn Header="Branch" Binding="{Binding Branch}" Width="*" MinWidth="80">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1D1D1F"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding GitHubIsPrivate}" Value="True"/>
                                                        <Condition Binding="{Binding HasStoredCredentials}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Foreground" Value="#EA580C"/>
                                                </MultiDataTrigger>
                                                <DataTrigger Binding="{Binding HasStoredCredentials}" Value="True">
                                                    <Setter Property="Foreground" Value="#EA580C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                <DataGridTemplateColumn Header="Local" Width="72" MinWidth="64">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LocalCloneText, Mode=OneWay}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#1D1D1F"/>
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding GitHubIsPrivate}" Value="True"/>
                                                                    <Condition Binding="{Binding HasStoredCredentials}" Value="False"/>
                                                                </MultiDataTrigger.Conditions>
                                                                <Setter Property="Foreground" Value="#EA580C"/>
                                                            </MultiDataTrigger>
                                                            <DataTrigger Binding="{Binding HasStoredCredentials}" Value="True">
                                                                <Setter Property="Foreground" Value="#EA580C"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="" Width="Auto" MinWidth="220">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="Preview"
                                                        Padding="8,4"
                                                        Margin="4,2,2,2"
                                                        Command="{Binding DataContext.Workspace.OpenRepositoryInBrowserCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Open repository URL in your browser"/>
                                                <Button Content="Edit"
                                                        Padding="8,4"
                                                        Margin="2,2,2,2"
                                                        Command="{Binding DataContext.Workspace.EditRepositoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Remove"
                                                        Padding="8,4"
                                                        Margin="2,2,4,2"
                                                        Command="{Binding DataContext.Workspace.RemoveRepositoryCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </TabItem>
            <TabItem Header="Log">
                <Border Background="White" BorderBrush="#DCDCDE" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Clear log" Command="{Binding ClearOutputCommand}" Padding="10,5"/>
                        </StackPanel>
                        <TextBox Text="{Binding Log.Text, Mode=OneWay}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontFamily="Cascadia Mono, Consolas, Courier New"
                                 FontSize="12"
                                 Foreground="#2D2D2D"
                                 Padding="0"/>
                    </DockPanel>
                </Border>
            </TabItem>
        </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="2" Background="#ECECEF" BorderBrush="#D0D0D4" BorderThickness="0,1,0,0" Padding="10,6">
            <DockPanel LastChildFill="True">
                <ProgressBar DockPanel.Dock="Left"
                             Width="56" Height="4"
                             Margin="0,0,10,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="{Binding StatusBar.IsBusy, Converter={StaticResource BoolToVis}}"/>
                <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12">
                    <TextBlock.Text>
                        <Binding Path="StatusBar.Message"/>
                    </TextBlock.Text>
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#2D2D2D"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusBar.IsError}" Value="True">
                                    <Setter Property="Foreground" Value="#B71C1C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </DockPanel>
        </Border>
    </Grid>
</Window>
