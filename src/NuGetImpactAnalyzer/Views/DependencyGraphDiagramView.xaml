<UserControl x:Class="NuGetImpactAnalyzer.Views.DependencyGraphDiagramView"

             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"

             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"

             xmlns:cg="clr-namespace:CodeGator.Wpf;assembly=CodeGator.Wpf"

             mc:Ignorable="d"

             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"

             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"

             d:DesignHeight="320" d:DesignWidth="480">

    <Border Background="#FAFAFB" BorderBrush="#DCDCDE" BorderThickness="1" CornerRadius="4" Padding="4">

        <Grid>

            <Grid.RowDefinitions>

                <RowDefinition Height="Auto"/>

                <RowDefinition Height="*"/>

            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,6">

                <Button x:Name="PrintDiagramButton"

                        DockPanel.Dock="Right"

                        Content="Print…"

                        Padding="12,4"

                        VerticalAlignment="Center"

                        Click="OnPrintDiagramClick"

                        ToolTip="Open the print dialog for the current dependency graph."/>

            </DockPanel>

            <cg:CgDiagram x:Name="Diagram"

                          Grid.Row="1"

                          NodeSize="64,84"

                          FontSize="11"

                          Nodes="{Binding DiagramNodes}"

                          Edges="{Binding DiagramEdges}"

                          ShowGrid="True"

                          GridOpacity="0.3"

                          EdgeStroke="#6B7280"

                          EdgeThickness="1.25"

                          MinHeight="260"/>

        </Grid>

    </Border>

</UserControl>

