<Window x:Class="NuGetImpactAnalyzer.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
  <StackPanel Margin="24" HorizontalAlignment="Stretch">
    <Image x:Name="AboutIcon"
           Width="96"
           Height="96"
           Stretch="Uniform"
           HorizontalAlignment="Center"
           Margin="0,0,0,16"
           RenderOptions.BitmapScalingMode="HighQuality"
           SnapsToDevicePixels="True" />
    <TextBlock x:Name="TitleText"
               FontSize="18"
               FontWeight="SemiBold"
               HorizontalAlignment="Center"
               TextAlignment="Center" />
    <TextBlock x:Name="VersionText"
               Margin="0,8,0,0"
               HorizontalAlignment="Center"
               TextAlignment="Center"
               Foreground="#333" />
    <TextBlock x:Name="CopyrightText"
               Margin="0,16,0,0"
               TextWrapping="Wrap"
               TextAlignment="Center"
               Foreground="#444" />
    <Button Content="OK"
            IsDefault="True"
            Width="90"
            Margin="0,24,0,0"
            HorizontalAlignment="Center"
            Click="Ok_Click" />
  </StackPanel>
</Window>
