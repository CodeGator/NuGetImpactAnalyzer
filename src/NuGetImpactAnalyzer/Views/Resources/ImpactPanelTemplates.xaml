<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:models="clr-namespace:NuGetImpactAnalyzer.Models">
    <DataTemplate x:Key="ImpactedPackageResultRow" DataType="{x:Type models:ImpactedPackageResult}">
        <Grid Margin="0,2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding DisplayLabel}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
            <Border Grid.Column="1"
                    CornerRadius="4"
                    Padding="8,2"
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    BorderThickness="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#ECEFF1"/>
                        <Setter Property="BorderBrush" Value="#90A4AE"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ImpactSeverity.Definite}">
                                <Setter Property="Background" Value="#C8E6C9"/>
                                <Setter Property="BorderBrush" Value="#2E7D32"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ImpactSeverity.Possible}">
                                <Setter Property="Background" Value="#FFECB3"/>
                                <Setter Property="BorderBrush" Value="#F57F17"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock FontSize="11" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="Possible"/>
                            <Setter Property="Foreground" Value="#E65100"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Severity}" Value="{x:Static models:ImpactSeverity.Definite}">
                                    <Setter Property="Text" Value="Definite"/>
                                    <Setter Property="Foreground" Value="#1B5E20"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </Grid>
    </DataTemplate>
</ResourceDictionary>
