<Window x:Class="NuGetImpactAnalyzer.Views.ChangeMasterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Change master password"
        Height="420" Width="460"
        MinHeight="380" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F4F6">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" TextWrapping="Wrap" FontSize="13" Foreground="#333"
                   Text="All stored HTTPS tokens will be re-encrypted. You must enter your current master password."/>

        <TextBlock Grid.Row="2" Text="Current master password" FontWeight="SemiBold" FontSize="13"/>
        <PasswordBox x:Name="PwCurrent" Grid.Row="4" Padding="8,6" FontSize="14" PasswordChanged="PwCurrent_OnPasswordChanged"/>

        <TextBlock Grid.Row="6" Text="New master password" FontWeight="SemiBold" FontSize="13"/>
        <PasswordBox x:Name="PwNew" Grid.Row="8" Padding="8,6" FontSize="14" PasswordChanged="PwNew_OnPasswordChanged"/>

        <TextBlock Grid.Row="10" Text="Confirm new master password" FontWeight="SemiBold" FontSize="13"/>
        <PasswordBox x:Name="PwConfirm" Grid.Row="12" Padding="8,6" FontSize="14" PasswordChanged="PwConfirm_OnPasswordChanged"/>

        <TextBlock Grid.Row="14" Text="{Binding ErrorMessage}" TextWrapping="Wrap" Foreground="#B91C1C" FontSize="12"/>

        <StackPanel Grid.Row="15" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Padding="14,8" Margin="0,0,8,0"
                    Command="{Binding CancelCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            <Button Content="Save" IsDefault="True" Padding="14,8"
                    Command="{Binding SaveCommand}" CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
        </StackPanel>
    </Grid>
</Window>
