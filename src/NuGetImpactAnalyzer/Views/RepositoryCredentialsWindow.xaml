<Window x:Class="NuGetImpactAnalyzer.Views.RepositoryCredentialsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="HTTPS credentials"
        Height="360" Width="440"
        MinHeight="300" MinWidth="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F4F4F6">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock TextWrapping="Wrap"
                       Foreground="#444"
                       FontSize="13"
                       Text="Personal access token for this repository’s name (as shown in the edit dialog). Tokens are stored in Windows Credential Manager for HTTPS remotes."/>
            <TextBlock Margin="0,8,0,0"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#B45309"
                       Visibility="{Binding IsCredentialKeyMissing, Converter={StaticResource BoolToVis}}">
                <Run Text="Save stays disabled until the repository "/>
                <Run FontWeight="SemiBold" Text="Name"/>
                <Run Text=" field is filled in on the edit dialog—that name is the key used to store the token."/>
            </TextBlock>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Personal access token" FontWeight="SemiBold" FontSize="13"/>
        <PasswordBox x:Name="TokenPasswordBox"
                     Grid.Row="4"
                     Padding="6,4"
                     FontSize="13"
                     PasswordChanged="TokenPasswordBox_OnPasswordChanged"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <Button Content="Save token" Command="{Binding SaveTokenCommand}" Padding="12,6" Margin="0,0,8,0"/>
            <Button Content="Remove stored token" Command="{Binding ClearStoredTokenCommand}" Padding="12,6"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" Visibility="{Binding HasStoredToken, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="A token is stored for this name." FontSize="12" Foreground="#2E7D32" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Grid.Row="10" Content="Close" IsDefault="True" IsCancel="True" Padding="16,8" HorizontalAlignment="Right"/>
    </Grid>
</Window>
